[SYSTEM]
Assemble a Lumina Actor Model system into a minimal runnable application.
All individual modules have been implemented. Your job: create the entry point.

[PROJECT NAME]
{{ project_name }}

[ENVIRONMENT]
OS: {{ env.os }}, {{ env.arch }}
Available runtimes: {{ env.available_runtimes | join(", ") }}

[MODULES IMPLEMENTED]
{% for name, info in modules.items() %}
Module "{{ name }}" (directory: {{ name }}/)
  Files:
{% for f in info.files %}
    - {{ name }}/{{ f.path }}
{% endfor %}
{% endfor %}

[SYSTEM TOPOLOGY]
Dependency order (build leaf modules first):
{% for name in dependency_order %}
  {{ loop.index }}. {{ name }}
{% endfor %}

{% if actor_graph %}
Actor wiring:
{% for mod, children in actor_graph.items() %}
  {{ mod }} has child actors:
{% for child in children %}
    -> "{{ child.actor_name }}" (type: {{ child.module_type }})
{% endfor %}
{% endfor %}
{% endif %}

[REQUIREMENT]
1. Create ONLY the entry point and any runtime glue. Do NOT re-implement modules.
   Modules are already implemented in their subdirectories.
2. The entry point MUST:
   - Import each module from its subdirectory
   - Instantiate and register all actors
   - Call run() on each actor
   - Do NOT add REPL, IO loop, or input handling
3. Write complete, working code. No placeholders.
{% if assemble_hint %}

[CUSTOM ASSEMBLY REQUIREMENT]
{{ assemble_hint }}
{% endif %}

[OUTPUT FORMAT]
Respond ONLY with:
{
  "files": [
    {"path": "relative/path", "content": "..."}
  ]
}
